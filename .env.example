# Sentinel — Autonomous Polymarket Trading Agent
# Copy this to .env and fill in your values

# === AI Analysis (optional — mock mode works without these) ===
ANTHROPIC_API_KEY=sk-ant-...
# Or use OpenAI:
# OPENAI_API_KEY=sk-...

# === Polymarket (required for live trading only) ===
POLYMARKET_PRIVATE_KEY=0x...
POLYMARKET_FUNDER_ADDRESS=0x...
POLYMARKET_SIG_TYPE=0  # 0=EOA, 1=Magic/Email, 2=Gnosis Safe

# === Execution ===
EXECUTION_MODE=paper  # "paper" or "live"
