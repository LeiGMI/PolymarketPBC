# Sentinel — Autonomous Polymarket Trading Agent
# Copy this to .env and fill in your values

# === LLM Analysis ===
# Set ONE of these. The agent auto-detects which provider to use.
# If neither is set, the analysis engine runs in mock mode (no API calls needed).
ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...

# Optional: override the default model
# LLM_MODEL=claude-sonnet-4-20250514   # or gpt-4o for OpenAI

# === Execution ===
# Only "paper" is currently supported. Live trading is on the roadmap.
EXECUTION_MODE=paper
